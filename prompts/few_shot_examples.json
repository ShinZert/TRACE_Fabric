        { "id": "decision_1", "type": "exclusiveGateway", "name": "Approved?" },
        { "id": "approve_loan", "type": "userTask", "name": "Approve Loan" },
        { "id": "reject_loan", "type": "userTask", "name": "Reject Application" },
        { "id": "notify_customer", "type": "serviceTask", "name": "Notify Customer" },
        { "id": "end_1", "type": "endEvent", "name": "Process Complete" }
      ],
      "flows": [
        { "id": "flow_1", "from": "start_1", "to": "review_application" },
        { "id": "flow_2", "from": "review_application", "to": "check_credit" },
        { "id": "flow_3", "from": "check_credit", "to": "decision_1" },
        { "id": "flow_4", "from": "decision_1", "to": "approve_loan", "name": "Yes" },
        { "id": "flow_5", "from": "decision_1", "to": "reject_loan", "name": "No" },
        { "id": "flow_6", "from": "approve_loan", "to": "notify_customer" },
        { "id": "flow_7", "from": "reject_loan", "to": "notify_customer" },
        { "id": "flow_8", "from": "notify_customer", "to": "end_1" }
      ]
    }
  },
  {
