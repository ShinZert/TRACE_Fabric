        { "id": "parallel_fork", "type": "parallelGateway", "name": "Start Parallel Tasks" },
        { "id": "it_setup", "type": "userTask", "name": "IT Equipment Setup" },
        { "id": "hr_orientation", "type": "userTask", "name": "HR Orientation" },
        { "id": "parallel_join", "type": "parallelGateway", "name": "All Tasks Complete" },
        { "id": "welcome_meeting", "type": "userTask", "name": "Welcome Meeting" },
        { "id": "end_1", "type": "endEvent", "name": "Onboarding Complete" }
      ],
      "flows": [
        { "id": "flow_1", "from": "start_1", "to": "create_account" },
        { "id": "flow_2", "from": "create_account", "to": "parallel_fork" },
        { "id": "flow_3", "from": "parallel_fork", "to": "it_setup" },
        { "id": "flow_4", "from": "parallel_fork", "to": "hr_orientation" },
        { "id": "flow_5", "from": "it_setup", "to": "parallel_join" },
        { "id": "flow_6", "from": "hr_orientation", "to": "parallel_join" },
        { "id": "flow_7", "from": "parallel_join", "to": "welcome_meeting" },
        { "id": "flow_8", "from": "welcome_meeting", "to": "end_1" }
      ]
    }
  }
