[
  {
    "user": "Create a simple order processing workflow",
    "assistant": {
      "process_name": "Order Processing",
      "elements": [
        { "id": "start_1", "type": "startEvent", "name": "Order Received" },
        { "id": "validate_order", "type": "serviceTask", "name": "Validate Order" },
        { "id": "process_payment", "type": "serviceTask", "name": "Process Payment" },
        { "id": "ship_order", "type": "userTask", "name": "Ship Order" },
        { "id": "send_confirmation", "type": "serviceTask", "name": "Send Confirmation" },
        { "id": "end_1", "type": "endEvent", "name": "Order Complete" }
      ],
      "flows": [
        { "id": "flow_1", "from": "start_1", "to": "validate_order" },
        { "id": "flow_2", "from": "validate_order", "to": "process_payment" },
        { "id": "flow_3", "from": "process_payment", "to": "ship_order" },
        { "id": "flow_4", "from": "ship_order", "to": "send_confirmation" },
        { "id": "flow_5", "from": "send_confirmation", "to": "end_1" }
      ]
    }
  },
  {
    "user": "Create a loan approval process with approval/rejection decision",
    "assistant": {
      "process_name": "Loan Approval",
      "elements": [
        { "id": "start_1", "type": "startEvent", "name": "Application Received" },
        { "id": "review_application", "type": "userTask", "name": "Review Application" },
